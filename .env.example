# Bybit API (use testnet keys first!)
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true

# Trading — comma-separated, no brackets (it's a plain string, not JSON)
SYMBOLS=BTCUSDT,ETHUSDT
CATEGORY=linear
BASE_TIMEFRAME=5

# Risk
MAX_LEVERAGE=3
RISK_PER_TRADE=0.01
VOL_TARGET_ANNUAL=0.15
DAILY_LOSS_LIMIT=0.03
MAX_DRAWDOWN=0.15
KELLY_FRACTION=0.25

# Paths
DATA_DIR=./data
ARTIFACT_DIR=./artifacts
LOG_DIR=./logs

# Ops
LOG_LEVEL=INFO

# Web control panel (RUN_MODE=web)
# Leave WEB_PASSWORD unset to disable auth (local dev only).
WEB_USERNAME=admin
WEB_PASSWORD=
PORT=8000

# Live trading safety — must equal "yes" to enable real orders
CONFIRM_LIVE=
